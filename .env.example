# Supabase (browser-safe keys only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public URL of your deployed site (no trailing slash). Required for production so auth emails
# (confirm signup, password reset) open your real domain instead of localhost.
# Local dev: http://localhost:5173 (or omit to use current origin)
# Production: https://your-domain.com
VITE_SITE_URL=
